@model UserManagementEditViewModel

@{
    ViewData["Title"] = "Edit user";
}

<div class="row">
    <div class="col-lg-6">
        <h1 class="h3 mb-3">Edit user</h1>
        <dl class="row">
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>
            <dt class="col-sm-4">Display name</dt>
            <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.DisplayName) ? "-" : Model.DisplayName)</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@(Model.IsLockedOut ? "Locked out" : "Active")</dd>
            <dt class="col-sm-4">Roles</dt>
            <dd class="col-sm-8">@Model.RoleSummary</dd>
        </dl>

        <form asp-action="UpdateAdminRole" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="IsAdmin" />
                <label class="form-check-label" asp-for="IsAdmin">Admin</label>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
